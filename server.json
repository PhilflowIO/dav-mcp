{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.PhilflowIO/dav-mcp",
  "description": "AI-orchestrated calendars, contacts & tasks across any DAV platform. 26 tools, field-agnostic.",
  "repository": {
    "url": "https://github.com/PhilflowIO/dav-mcp",
    "source": "github"
  },
  "version": "3.0.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "dav-mcp",
      "version": "3.0.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DAV_BASE_URL",
          "description": "Base URL of your CalDAV/CardDAV server",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "DAV_USERNAME",
          "description": "Username for DAV server authentication",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "DAV_PASSWORD",
          "description": "Password for DAV server authentication",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
